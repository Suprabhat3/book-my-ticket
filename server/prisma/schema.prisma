generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  USER
}

enum ScreenType {
  ELITE
  PREMIUM
  NORMAL
}

enum SeatType {
  REGULAR
  RECLINER
  PREMIUM
}

enum ShowStatus {
  SCHEDULED
  CANCELLED
  COMPLETED
}

enum SeatBookingStatus {
  AVAILABLE
  LOCKED
  BOOKED
}

enum BookingStatus {
  PENDING
  PAID
  FAILED
  CANCELLED
}

enum PaymentStatus {
  CREATED
  AUTHORIZED
  CAPTURED
  FAILED
}

model User {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  passwordHash String
  role         Role      @default(USER)
  refreshToken String?
  bookings     Booking[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model City {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  state     String?
  country   String    @default("India")
  isActive  Boolean   @default(true)
  theaters  Theater[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Theater {
  id          Int       @id @default(autoincrement())
  cityId      Int
  name        String
  slug        String?
  addressLine String
  pincode     String?
  latitude    Float?
  longitude   Float?
  isActive    Boolean   @default(true)
  city        City      @relation(fields: [cityId], references: [id], onDelete: Restrict)
  screens     Screen[]
  shows       Show[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([cityId, name])
  @@index([cityId])
}

model Screen {
  id            Int          @id @default(autoincrement())
  theaterId     Int
  name          String
  screenType    ScreenType
  totalRows     Int
  totalCols     Int
  seatCapacity  Int
  layoutProfile Json?
  isActive      Boolean      @default(true)
  theater       Theater      @relation(fields: [theaterId], references: [id], onDelete: Restrict)
  seats         ScreenSeat[]
  shows         Show[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@unique([theaterId, name])
  @@index([theaterId])
}

model ScreenSeat {
  id         Int        @id @default(autoincrement())
  screenId   Int
  rowLabel   String
  seatNumber Int
  seatLabel  String
  zone       String?
  seatType   SeatType   @default(REGULAR)
  isActive   Boolean    @default(true)
  screen     Screen     @relation(fields: [screenId], references: [id], onDelete: Restrict)
  showSeats  ShowSeat[]
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  @@unique([screenId, seatLabel])
  @@index([screenId])
}

model Movie {
  id                   Int       @id @default(autoincrement())
  title                String
  description          String
  durationMinutes      Int
  language             String
  genre                String
  releaseDate          DateTime
  censorRating         String?
  posterUrl            String?
  posterImagekitFileId String?
  posterVerticalUrl            String?
  posterVerticalImagekitFileId String?
  posterHorizontalUrl          String?
  posterHorizontalImagekitFileId String?
  trailerUrl           String?
  isActive             Boolean   @default(true)
  shows                Show[]
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@index([releaseDate])
}

model Show {
  id         Int         @id @default(autoincrement())
  movieId    Int
  theaterId  Int
  screenId   Int
  startTime  DateTime
  endTime    DateTime
  basePrice      Decimal     @db.Decimal(10, 2)
  pricingProfile Json?
  status         ShowStatus  @default(SCHEDULED)
  movie          Movie       @relation(fields: [movieId], references: [id], onDelete: Restrict)
  theater    Theater     @relation(fields: [theaterId], references: [id], onDelete: Restrict)
  screen     Screen      @relation(fields: [screenId], references: [id], onDelete: Restrict)
  showSeats  ShowSeat[]
  bookings   Booking[]
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  @@index([movieId, startTime])
  @@index([theaterId, startTime])
  @@index([screenId, startTime])
}

model ShowSeat {
  id            Int               @id @default(autoincrement())
  showId        Int
  screenSeatId  Int
  price         Decimal           @db.Decimal(10, 2)
  status        SeatBookingStatus @default(AVAILABLE)
  lockedUntil   DateTime?
  lockedByUserId String?
  show          Show              @relation(fields: [showId], references: [id], onDelete: Restrict)
  screenSeat    ScreenSeat        @relation(fields: [screenSeatId], references: [id], onDelete: Restrict)
  bookingSeats  BookingSeat[]
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@unique([showId, screenSeatId])
  @@index([showId, status])
  @@index([showId, lockedByUserId])
}

model Booking {
  id          String        @id @default(cuid())
  userId      String
  showId      Int
  status      BookingStatus @default(PENDING)
  totalAmount Decimal       @db.Decimal(10, 2)
  user        User          @relation(fields: [userId], references: [id], onDelete: Restrict)
  show        Show          @relation(fields: [showId], references: [id], onDelete: Restrict)
  seats       BookingSeat[]
  payment     Payment?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([userId, createdAt])
  @@index([showId])
}

model BookingSeat {
  id         Int      @id @default(autoincrement())
  bookingId  String
  showSeatId Int
  price      Decimal  @db.Decimal(10, 2)
  booking    Booking  @relation(fields: [bookingId], references: [id], onDelete: Restrict)
  showSeat   ShowSeat @relation(fields: [showSeatId], references: [id], onDelete: Restrict)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([bookingId, showSeatId])
  @@index([showSeatId])
}

model Payment {
  id                 String        @id @default(cuid())
  bookingId          String        @unique
  provider           String        @default("RAZORPAY")
  status             PaymentStatus @default(CREATED)
  amount             Decimal       @db.Decimal(10, 2)
  currency           String        @default("INR")
  razorpayOrderId    String?       @unique
  razorpayPaymentId  String?       @unique
  razorpaySignature  String?
  rawWebhookPayload  Json?
  booking            Booking       @relation(fields: [bookingId], references: [id], onDelete: Restrict)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
}
